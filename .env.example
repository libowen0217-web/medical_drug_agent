# =========================
# LLM configuration
# =========================

# Optional: auto / openai / anthropic
LLM_PROVIDER=auto

# Do not commit real API keys.
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://your-openai-compatible-base-url/v1
LLM_MODEL=your_model_name_here

# Optional debug switch. Keep false unless troubleshooting provider responses.
LLM_DEBUG=false


# =========================
# Knowledge graph backend
# =========================

# Optional: csv / neo4j / auto
# csv   : use local CSV only
# neo4j : require Neo4j
# auto  : prefer Neo4j when available, fallback to CSV
KG_BACKEND=auto

# Neo4j is accessed by the backend process on this machine.
# Keep 127.0.0.1 here when Neo4j runs locally beside FastAPI.
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j


# =========================
# Frontend optional override
# =========================

# Leave empty for Vite dev proxy: browser -> Vue 5173 -> FastAPI 8000.
# Set only when the frontend must call a remote API server directly.
VITE_API_BASE_URL=
