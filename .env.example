# =========================
# LLM 报告润色配置
# =========================

# 是否默认启用 LLM 报告润色；真实调用仍依赖 API Key / Base URL / Model 是否正确配置。
LLM_ENABLED=true

# 可选：auto / openai / anthropic / your_provider
LLM_PROVIDER=your_provider

# 不要在示例文件中填写真实 API Key、Token 或密码。
LLM_BASE_URL=https://your-llm-endpoint
LLM_API_KEY=your_api_key_here
LLM_MODEL=your_model_name

# 调试 provider 响应时可设为 true；提交代码前请保持 false。
LLM_DEBUG=false


# =========================
# Neo4j / 知识图谱后端配置
# =========================

# 是否启用 Neo4j 能力；当前项目也支持 CSV 本地回退。
NEO4J_ENABLED=false

# KG_BACKEND 可选：csv / neo4j / auto
# csv   : 只使用本地 CSV
# neo4j : 强制使用 Neo4j
# auto  : 优先 Neo4j，不可用时回退 CSV
KG_BACKEND=csv

# Neo4j 是后端进程访问数据库，不是浏览器直接访问。
NEO4J_URI=bolt://localhost:7687

# 当前代码读取 NEO4J_USER；NEO4J_USERNAME 保留给部署文档或外部工具兼容。
NEO4J_USER=neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j


# =========================
# RAG 本地文档知识库配置
# =========================

RAG_ENABLED=true
RAG_MODEL_PATH=models/bge-small-zh-v1.5
RAG_DOCS_DIR=data/rag_docs
RAG_CHROMA_PATH=data/vector_db/chroma
RAG_TOP_K=5


# =========================
# 本地数据文件
# =========================

DRUG_DATA_PATH=data/processed/primekg_core100_drug_dataset.csv


# =========================
# FastAPI / 前端开发配置
# =========================

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Vue/Vite 默认通过同源 /api 代理访问后端。通常保持为空即可。
VITE_API_BASE_URL=


# =========================
# 审计与日志
# =========================

AUDIT_ENABLED=true
LOG_LEVEL=INFO
